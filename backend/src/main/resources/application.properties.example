## Example application.properties for the team
# Copy this file to `application.properties` and set real values or
# set the environment variables shown below.

spring.application.name=backend

# Example using explicit values (do NOT commit real secrets)
# spring.datasource.url=jdbc:postgresql://aws-1-ap-south-1.pooler.supabase.com:5432/postgres
# spring.datasource.username=postgres
# spring.datasource.password=changeme

# Recommended: use environment variables
spring.datasource.url=${SPRING_DATASOURCE_URL}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD}

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true